{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "1280px",
			"wideSize": "1280px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"customDuotone": false,
			"palette": [
				{ "slug": "ink", "color": "#1D1D1B", "name": "Carbón" },
				{ "slug": "ink-soft", "color": "#2A2A28", "name": "Carbón suave" },
				{ "slug": "navy", "color": "#1E222E", "name": "Navy" },
				{ "slug": "paper", "color": "#F5F5F5", "name": "Off-white" },
				{ "slug": "paper-soft", "color": "#FAFAFA", "name": "Off-white claro" },
				{ "slug": "bone", "color": "#FFFFFF", "name": "Blanco" },
				{ "slug": "rust", "color": "#E20613", "name": "Rojo XP" },
				{ "slug": "rust-deep", "color": "#B70510", "name": "Rojo profundo" },
				{ "slug": "steel", "color": "#7A7A7A", "name": "Gris" },
				{ "slug": "line", "color": "#E5E5E5", "name": "Línea" }
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"customFontSize": true,
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "display",
					"name": "Montserrat",
					"fontFamily": "Montserrat, system-ui, -apple-system, 'Segoe UI', sans-serif",
					"fontFace": []
				},
				{
					"slug": "body",
					"name": "Montserrat",
					"fontFamily": "Montserrat, system-ui, -apple-system, 'Segoe UI', sans-serif",
					"fontFace": []
				},
				{
					"slug": "accent",
					"name": "Saira Stencil",
					"fontFamily": "'Saira Stencil One', 'Saira Condensed', 'Arial Narrow', sans-serif",
					"fontFace": []
				},
				{
					"slug": "italic-display",
					"name": "Saira Condensed Italic",
					"fontFamily": "'Saira Condensed', 'Arial Narrow', sans-serif",
					"fontFace": []
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.875rem", "name": "Pequeño" },
				{ "slug": "medium", "size": "1rem", "name": "Mediano" },
				{ "slug": "large", "size": "1.25rem", "name": "Grande" },
				{ "slug": "x-large", "size": "2rem", "name": "Extra grande" },
				{ "slug": "huge", "size": "clamp(2.5rem, 6vw, 4.5rem)", "name": "Hero" },
				{ "slug": "kinetic", "size": "clamp(3.4rem, 10vw, 8rem)", "name": "Cinético" }
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"customSpacingSize": true,
			"units": [ "px", "em", "rem", "%", "vh", "vw", "svh" ],
			"spacingSizes": [
				{ "slug": "20", "size": "0.5rem", "name": "2 — XS" },
				{ "slug": "30", "size": "1rem", "name": "3 — S" },
				{ "slug": "40", "size": "1.5rem", "name": "4 — M" },
				{ "slug": "50", "size": "2.5rem", "name": "5 — L" },
				{ "slug": "60", "size": "4rem", "name": "6 — XL" },
				{ "slug": "70", "size": "6rem", "name": "7 — 2XL" },
				{ "slug": "80", "size": "8rem", "name": "8 — 3XL" }
			],
			"blockGap": true,
			"padding": true,
			"margin": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{ "slug": "card", "name": "Card", "shadow": "0 1px 0 rgba(29,29,27,0.04), 0 8px 24px -12px rgba(29,29,27,0.18)" },
				{ "slug": "card-lift", "name": "Card lift", "shadow": "0 1px 0 rgba(29,29,27,0.06), 0 22px 48px -18px rgba(226,6,19,0.22)" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--paper)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "1rem",
			"lineHeight": "1.6"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "900",
					"textTransform": "uppercase",
					"letterSpacing": "-0.015em",
					"lineHeight": "1"
				}
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--ink)" },
				":hover": { "color": { "text": "var(--wp--preset--color--rust)" } }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--rust)",
					"text": "var(--wp--preset--color--bone)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "700",
					"textTransform": "uppercase",
					"letterSpacing": "0.06em",
					"fontSize": "0.875rem"
				},
				"border": { "radius": "0.375rem" },
				"spacing": {
					"padding": {
						"top": "0.875rem",
						"bottom": "0.875rem",
						"left": "1.5rem",
						"right": "1.5rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--rust-deep)",
						"text": "var(--wp--preset--color--bone)"
					}
				}
			}
		}
	}
}
